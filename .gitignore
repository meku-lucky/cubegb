# ---------------------------------------------------------------------------
# Agent-only documentation — NOT published to the public repo.
# (Maintainer owns these lines and may adjust them; see AGENTS.md.)
# `docs-agents/` is agent-only; `docs/` is published.
/AGENTS.md
/CLAUDE.md
/docs-agents/
# ---------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Model weights / large artifacts (download separately — see docs/recognition.md)
*.pth
*.pt
*.onnx
*.ckpt
*.safetensors

# Local output dir (ComfyUI Save/Bake fallback when run outside ComfyUI)
/output/

# Generated meshes / debug output (the .cgb source is committed; bakes are not)
*.glb
*.gltf
*.obj
*.ply
!samples/**

# Recognition eval/debug output + scratch artifacts (regenerate via
# recognition.debug and the test_images/_synth.py / _fetch.py scripts).
/debug_out/
/test_result*.cgb
/test_scene.png
# Test images: ignore by default, but DO commit the AI-generated concept art /
# 2x2 multi-view sheets and our own synthetic primitives. Third-party downloads
# (e.g. Wikimedia chair.png / fire_hydrant.jpg / traffic_cone.jpg) stay ignored
# to avoid redistributing other people's images — see test_images/_SOURCES.md.
/test_images/*.png
/test_images/*.jpg
/test_images/*.jpeg
!/test_images/*_concept.png
!/test_images/concept_*.png
!/test_images/*_2x2_views.png
!/test_images/synth_*.png

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
